/* ============================================
   任务领取小程序 — 全局样式系统
   设计风格：暖黄活力 · 白色卡片 · 圆角层次
   ============================================ */

/* === 色彩变量（通过 CSS 变量维护） === */
page {
  /* 黄色系主色 */
  --primary-dark: #E8B923;     /* 金黄深调 */
  --primary-mid: #FFD93D;      /* 金黄中调 · 品牌主要识别 */
  --primary-light: #FFF5C2;    /* 金黄浅调 */

  /* 橙色系强调 */
  --orange-dark: #FF6B35;      /* 橙红深调 */
  --orange-mid: #FF8C42;       /* 橙红中调 */
  --orange-light: #FFE5D6;     /* 橙红浅底色 */

  /* 价格/高亮红 */
  --accent: #FF4D4D;           /* 活力红 */
  --accent-light: #FFF0F0;     /* 红浅底色 */
  --accent-glow: rgba(255, 77, 77, 0.25);

  /* 背景 */
  --bg-page: #F5F5F5;          /* 浅灰底 */
  --bg-card: #FFFFFF;          /* 纯白卡片 */
  --bg-card-solid: #FFFFFF;    /* 兜底 */
  --bg-divider: #EEEEEE;

  /* 卡片层次（去毛玻璃，用实色+阴影） */
  --glass-bg-light: #FFFFFF;
  --glass-bg-medium: #FFFFFF;
  --glass-border: #F0F0F0;
  --glass-blur: 0rpx;

  /* 文字 */
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-placeholder: #999999;
  --text-white: #FFFFFF;

  /* 功能色 */
  --success: #52C41A;          /* 翠绿 */
  --success-bg: rgba(82, 196, 26, 0.10);
  --warning: #FAAD14;          /* 金黄警告 */
  --warning-bg: rgba(250, 173, 20, 0.10);
  --error: #FF4D4D;            /* 红 */
  --error-bg: rgba(255, 77, 77, 0.10);
  --info: #FF8C42;             /* 橙 */
  --info-bg: rgba(255, 140, 66, 0.10);

  /* 间距 */
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-md: 12px;
  --spacing-lg: 16px;
  --spacing-xl: 24px;
  --spacing-xxl: 32px;

  /* 圆角 ≥16rpx */
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-round: 999px;

  /* 阴影层次 — 暖灰基调 */
  --shadow-xs: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-sm: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --shadow-card: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  --shadow-float: 0 12rpx 40rpx rgba(0, 0, 0, 0.10);
  --shadow-glow: 0 0 40rpx rgba(255, 140, 66, 0.15);

  box-sizing: border-box;
  background: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Noto Sans SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* === 全局重置 === */
button {
  background: initial;
  padding: 0;
  margin: 0;
  line-height: inherit;
  font-size: inherit;
}
button:focus { outline: 0; }
button::after { border: none; }

/* === 布局 === */
.page-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-content {
  flex: 1;
  padding-bottom: var(--spacing-xxl);
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* === 卡片（白色实色款） === */
.card {
  margin: var(--spacing-md) var(--spacing-lg);
  padding: var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  border: none;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}
.card:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-sm);
}

/* === 按钮 === */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: var(--primary-mid);
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-round);
  margin: 0 var(--spacing-lg);
  border: none;
}
.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}
.btn-primary[disabled] {
  background: #E0E0E0;
  opacity: 0.6;
}

.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: transparent;
  color: var(--orange-dark);
  font-size: 28rpx;
  font-weight: 500;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--orange-dark);
}
.btn-outline:active {
  background: var(--orange-light);
}

.btn-text {
  display: inline-flex;
  align-items: center;
  color: var(--orange-dark);
  font-size: 26rpx;
  font-weight: 500;
  background: transparent;
  border: none;
}
.btn-text:active { opacity: 0.7; }

.btn-sm {
  height: 64rpx;
  padding: 0 32rpx;
  font-size: 26rpx;
  border-radius: var(--radius-sm);
}

.btn-block {
  width: 100%;
}

/* === 输入框 === */
.input-group {
  margin: 0 var(--spacing-lg) var(--spacing-md);
}

.input-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

.input-field {
  width: 100%;
  height: 96rpx;
  padding: 0 var(--spacing-lg);
  background: var(--bg-page);
  border: 2rpx solid var(--bg-divider);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}
.input-field:focus {
  border-color: var(--primary-mid);
}
.input-field::placeholder {
  color: var(--text-placeholder);
}

.input-error {
  border-color: var(--error) !important;
}
.input-error-msg {
  font-size: 24rpx;
  color: var(--error);
  margin-top: var(--spacing-xs);
  padding-left: var(--spacing-sm);
}

/* === 文字样式 === */
.text-h1 {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
}
.text-h2 {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
}
.text-h3 {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.5;
}
.text-body {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}
.text-caption {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}
.text-mini {
  font-size: 20rpx;
  color: var(--text-placeholder);
}

.text-secondary { color: var(--text-secondary); }
.text-accent { color: var(--accent); }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }
.text-error { color: var(--error); }
.text-white { color: var(--text-white); }
.text-center { text-align: center; }
.text-right { text-align: right; }

.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* === 分割线 === */
.divider {
  height: 2rpx;
  background: var(--bg-divider);
  margin: var(--spacing-md) 0;
}

.divider-thin {
  height: 1rpx;
  background: var(--bg-divider);
}

/* === 间距工具类 === */
.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mt-xl { margin-top: var(--spacing-xl); }

.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }

.p-lg { padding: var(--spacing-lg); }

/* === 弹性布局 === */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.flex-col {
  display: flex;
  flex-direction: column;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-1 { flex: 1; }

/* === 标签徽章 === */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: var(--radius-sm);
  line-height: 1.6;
}

.badge-auditing {
  background: rgba(250, 173, 20, 0.12);
  color: #D48806;
}
.badge-progress {
  background: rgba(255, 140, 66, 0.12);
  color: #FF6B35;
}
.badge-done {
  background: rgba(82, 196, 26, 0.12);
  color: #389E0D;
}
.badge-settled {
  background: rgba(255, 109, 109, 0.12);
  color: #FF4D4D;
}
.badge-rejected {
  background: rgba(255, 77, 77, 0.12);
  color: #FF4D4D;
}
.badge-success {
  background: var(--success-bg);
  color: var(--success);
}
.badge-warning {
  background: var(--warning-bg);
  color: var(--warning);
}
.badge-error {
  background: var(--error-bg);
  color: var(--error);
}

/* === 认证状态图标行 === */
.auth-status-row {
  display: flex;
  align-items: center;
  gap: 32rpx;
}
.auth-status-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.auth-status-item.passed {
  color: var(--success);
}
.auth-status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--bg-divider);
}
.auth-status-dot.passed {
  background: var(--success);
}
.auth-status-dot.warning {
  background: var(--warning);
}

/* === 进度条 === */
.progress-bar {
  height: 12rpx;
  background: var(--bg-divider);
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD93D, #FF8C42);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* === 步骤条 === */
.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: 24rpx var(--spacing-lg);
}
.step-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.step-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  background: var(--bg-divider);
  color: var(--text-placeholder);
}
.step-circle.active {
  background: var(--primary-mid);
  color: var(--text-primary);
  box-shadow: 0 0 0 6rpx rgba(255, 217, 61, 0.25);
}
.step-circle.done {
  background: var(--primary-mid);
  color: var(--text-primary);
}
.step-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}
.step-label.active {
  color: var(--orange-dark);
  font-weight: 500;
}
.step-line {
  width: 60rpx;
  height: 4rpx;
  background: var(--bg-divider);
  margin: 0 8rpx;
}
.step-line.done {
  background: var(--primary-mid);
}

/* === Toast 动画 === */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeOutDown {
  from { opacity: 1; transform: translateY(0); }
  to { opacity: 0; transform: translateY(20rpx); }
}
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* === 底部操作栏 === */
.bottom-action-bar {
  padding: var(--spacing-lg);
  padding-bottom: calc(var(--spacing-lg) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--spacing-lg) + env(safe-area-inset-bottom));
  background: var(--bg-card);
  box-shadow: 0 -2px 16px rgba(0, 0, 0, 0.04);
}

/* === 列表项 === */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg);
  background: var(--bg-card);
}
.list-item + .list-item {
  border-top: 1rpx solid var(--bg-divider);
}
.list-item-arrow::after {
  content: '';
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid var(--text-placeholder);
  border-top: 3rpx solid var(--text-placeholder);
  transform: rotate(45deg);
  margin-left: var(--spacing-sm);
}
.list-item-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: var(--spacing-md);
}
.list-item-label {
  font-size: 28rpx;
  color: var(--text-primary);
}
.list-item-value {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* === 标签按钮（筛选器等） === */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: var(--radius-round);
  background: var(--bg-page);
  color: var(--text-secondary);
  transition: all 0.2s;
}
.tag.active {
  background: var(--primary-mid);
  color: var(--text-primary);
}

/* === 页面顶部横幅 === */
.banner-warning {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--warning-bg);
  color: var(--warning);
  font-size: 26rpx;
  margin: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-md);
}
