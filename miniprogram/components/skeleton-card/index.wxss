/* components/skeleton-card/index.wxss */
.skeleton-card {
  margin: var(--spacing-md) var(--spacing-lg);
  padding: var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.sk-line {
  height: 24rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, var(--bg-divider) 25%, var(--bg-page) 50%, var(--bg-divider) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-bottom: 16rpx;
}

.sk-title {
  width: 80%;
  height: 32rpx;
}

.sk-subtitle {
  width: 50%;
  height: 28rpx;
}

.sk-body {
  width: 100%;
  height: 24rpx;
}

.sk-foot {
  width: 60%;
  height: 24rpx;
  margin-top: 12rpx;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
