/* ============================================
   task-card · 暖黄活力白色卡片风格
   ============================================ */

.task-card {
  margin: 16rpx 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.task-card:active {
  transform: scale(0.985);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

/* 左侧黄色装饰条 */
.card-accent-bar {
  width: 8rpx;
  background: linear-gradient(180deg, #FFD93D 0%, #FF8C42 100%);
  flex-shrink: 0;
}

/* 卡片内容区 */
.card-content {
  flex: 1;
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 顶部行：标题 + 日期 */
.card-row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.task-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.task-date {
  font-size: 24rpx;
  color: #999999;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 企业名称 */
.task-enterprise {
  font-size: 26rpx;
  color: #999999;
}

/* 底部行：收费 + 按钮 */
.card-row-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4rpx;
}

.task-fee {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--accent);
}

/* 报名按钮 · 黄色胶囊 */
.btn-signup {
  padding: 10rpx 28rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
  background: linear-gradient(135deg, #FFD93D 0%, #FFEB3B 100%);
  border-radius: 28rpx;
  white-space: nowrap;
  box-shadow: 0 4rpx 12rpx rgba(255, 217, 61, 0.25);
}
.btn-signup:active {
  transform: scale(0.95);
}

/* 已领取 · 绿色徽章 */
.btn-claimed {
  padding: 10rpx 28rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--success);
  background: var(--success-bg);
  border-radius: 28rpx;
  white-space: nowrap;
}
