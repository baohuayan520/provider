<!-- 四要素认证 — 第1步/共3步 -->
<view class="page-container">
  <!-- 步骤条 -->
  <view class="steps-wrap card">
    <text class="steps-title text-h3">领取进度</text>
    <view class="steps">
      <view class="step-item">
        <view class="step-circle active">1</view>
        <text class="step-label active">四要素</text>
      </view>
      <view class="step-line"></view>
      <view class="step-item">
        <view class="step-circle">2</view>
        <text class="step-label">活体认证</text>
      </view>
      <view class="step-line"></view>
      <view class="step-item">
        <view class="step-circle">3</view>
        <text class="step-label">签署协议</text>
      </view>
    </view>
  </view>

  <!-- 已认证提示 -->
  <view wx:if="{{alreadyVerified}}" class="verified-tip banner-warning">
    ✅ 四要素已认证通过，即将进入下一步...
  </view>

  <scroll-view wx:else scroll-y class="scroll-content">
    <!-- 表单 -->
    <view class="form-card card">
      <view class="input-group">
        <text class="input-label">真实姓名</text>
        <input
          class="input-field {{errors.name ? 'input-error' : ''}}"
          placeholder="请输入真实姓名"
          value="{{form.name}}"
          data-field="name"
          bindinput="onInput"
          bindblur="validateField"
          maxlength="20"
        />
        <text wx:if="{{errors.name}}" class="input-error-msg">{{errors.name}}</text>
      </view>

      <view class="input-group">
        <text class="input-label">身份证号码</text>
        <input
          class="input-field {{errors.idCard ? 'input-error' : ''}}"
          placeholder="请输入18位身份证号"
          value="{{form.idCard}}"
          data-field="idCard"
          bindinput="onInput"
          bindblur="validateField"
          type="idcard"
          maxlength="18"
        />
        <text wx:if="{{errors.idCard}}" class="input-error-msg">{{errors.idCard}}</text>
      </view>

      <view class="input-group">
        <text class="input-label">银行卡号</text>
        <input
          class="input-field {{errors.bankCard ? 'input-error' : ''}}"
          placeholder="请输入银行卡号"
          value="{{form.bankCard}}"
          data-field="bankCard"
          bindinput="onInput"
          bindblur="validateField"
          type="number"
          maxlength="19"
        />
        <text wx:if="{{errors.bankCard}}" class="input-error-msg">{{errors.bankCard}}</text>
      </view>

      <view class="input-group">
        <text class="input-label">手机号码</text>
        <input
          class="input-field {{errors.phone ? 'input-error' : ''}}"
          placeholder="请输入手机号码"
          value="{{form.phone}}"
          data-field="phone"
          bindinput="onInput"
          bindblur="validateField"
          type="number"
          maxlength="11"
        />
        <text wx:if="{{errors.phone}}" class="input-error-msg">{{errors.phone}}</text>
      </view>
    </view>

    <!-- 工作技能 -->
    <view class="form-card card">
      <text class="text-h3">工作技能（可多选）</text>
      <text class="text-caption" style="margin-top:8rpx;display:block;">选择您擅长的工作技能，有助于匹配更合适的任务</text>
      <view class="skills-wrap">
        <view
          wx:for="{{skillOptions}}"
          wx:key="*this"
          class="skill-tag {{form.skills.indexOf(item) > -1 ? 'skill-tag--active' : ''}}"
          data-skill="{{item}}"
          bindtap="toggleSkill"
        >{{item}}</view>
      </view>
    </view>

    <!-- 身份证照片 -->
    <view class="form-card card">
      <text class="text-h3">身份证照片</text>
      <text class="text-caption" style="margin-top:8rpx;display:block;">请上传身份证正反面清晰照片</text>

      <view class="idcard-upload-row">
        <!-- 正面 -->
        <view class="idcard-upload-item" data-field="idCardFrontUrl" bindtap="handleIdcardClick">
          <image wx:if="{{idCardFrontUrl}}" class="idcard-preview" src="{{idCardFrontUrl}}" mode="aspectFill" />
          <view wx:else class="idcard-placeholder">
            <text class="idcard-placeholder-icon">📷</text>
            <text class="idcard-placeholder-text">正面照</text>
          </view>
          <view wx:if="{{idCardFrontUrl}}" class="idcard-delete" data-field="idCardFrontUrl" catchtap="removeImage">✕</view>
          <text wx:if="{{uploadingFront}}" class="uploading-tip">上传中...</text>
        </view>

        <!-- 反面 -->
        <view class="idcard-upload-item" data-field="idCardBackUrl" bindtap="handleIdcardClick">
          <image wx:if="{{idCardBackUrl}}" class="idcard-preview" src="{{idCardBackUrl}}" mode="aspectFill" />
          <view wx:else class="idcard-placeholder">
            <text class="idcard-placeholder-icon">📷</text>
            <text class="idcard-placeholder-text">反面照</text>
          </view>
          <view wx:if="{{idCardBackUrl}}" class="idcard-delete" data-field="idCardBackUrl" catchtap="removeImage">✕</view>
          <text wx:if="{{uploadingBack}}" class="uploading-tip">上传中...</text>
        </view>
      </view>
    </view>

    <view style="height:140rpx;"></view>
  </scroll-view>

  <!-- 底部提交按钮 -->
  <view class="bottom-action-bar">
    <button
      class="btn-primary btn-block"
      bindtap="submitIdentity"
      loading="{{submitting}}"
      disabled="{{submitting}}"
    >提交认证</button>
  </view>
</view>
