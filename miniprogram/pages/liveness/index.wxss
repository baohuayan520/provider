.page-container {
  min-height: 100vh;
  background: var(--bg-page);
  display: flex;
  flex-direction: column;
}

.steps-wrap {
  margin: 0;
  border-radius: 0;
  padding: 24rpx var(--spacing-lg);
}

.steps-title {
  text-align: center;
  margin-bottom: 16rpx;
}

.status-card {
  margin: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx var(--spacing-lg);
}

.status-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
}
.status-icon-wrap.success {
  background: var(--success-bg);
}
.status-icon-wrap.warning {
  background: var(--warning-bg);
}
.status-icon-wrap.error {
  background: var(--error-bg);
}

.status-icon {
  font-size: 60rpx;
}

.notice-box {
  width: 100%;
  margin-top: 32rpx;
  padding: var(--spacing-lg);
  background: var(--bg-page);
  border-radius: var(--radius-md);
}

.notice-item {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
  line-height: 1.6;
}
