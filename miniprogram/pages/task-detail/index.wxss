.page-container {
  min-height: 100vh;
  background: var(--bg-page);
  display: flex;
  flex-direction: column;
}

.loading-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-img {
  width: 100%;
  height: 400rpx;
}

.cover-placeholder {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, var(--primary-mid), var(--primary-light));
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-placeholder-text {
  font-size: 36rpx;
  color: var(--text-white);
  font-weight: 600;
}

.detail-section {
  margin: var(--spacing-md) var(--spacing-lg);
  padding: var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.detail-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) 0;
}

.detail-row + .detail-row {
  border-top: 1rpx solid var(--bg-divider);
}

.detail-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.detail-value {
  font-size: 26rpx;
  color: var(--text-primary);
}

.status-detail {
  margin-top: var(--spacing-md);
  display: flex;
  flex-direction: column;
}

/* 硬性要求列表 */
.requirements-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.req-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.req-dot {
  font-size: 20rpx;
  color: var(--accent);
  line-height: 1.8;
  flex-shrink: 0;
}

.req-text {
  flex: 1;
}

/* 硬性描述 */
.req-description {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: var(--bg-page);
  border-radius: var(--radius-md);
  border-left: 6rpx solid var(--accent);
}

.cant-claim-hint {
  text-align: center;
  padding: var(--spacing-md);
}

/* 技能标签 */
.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.skill-tag-detail {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: var(--accent);
  background: var(--accent-light);
  border-radius: var(--radius-round);
  font-weight: 500;
}
